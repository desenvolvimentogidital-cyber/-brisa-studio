{
  "name": "mobile-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "electron:dev": "concurrently \"vite --port=5173\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && tsc -p tsconfig.electron.json && electron-builder",
    "electron:build:win": "vite build && tsc -p tsconfig.electron.json && electron-builder --win",
    "electron:build:portable": "vite build && tsc -p tsconfig.electron.json && electron-builder --win portable",
    "electron:preview": "vite build && electron ."
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^0.546.0",
    "monaco-editor": "^0.56.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  },
  "overrides": {
    "dompurify": "3.4.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10"
  }
}
